{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./public/build",
        "rootDir": "./resources/ts"
    },
    "include": ["resources/ts/**/*.ts"],
    "exclude": ["node_modules"]
}
